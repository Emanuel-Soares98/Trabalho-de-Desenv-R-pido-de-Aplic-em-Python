def ler_numero(mensagem):
    while True:
        numero = input(mensagem).strip()
        if numero.lstrip('-').isdigit():
            return int(numero)
        print("Entrada inválida! Digite apenas números inteiros.")

while True:
    num1 = ler_numero("Digite o primeiro número inteiro: ")

    operacao = input("Escolha a operação (+, -, *, /): ").strip()
    while operacao not in ["+", "-", "*", "/"]:
        print("Operação inválida! Escolha apenas +, -, * ou /")
        operacao = input("Escolha a operação (+, -, *, /): ").strip()

    num2 = ler_numero("Digite o segundo número inteiro: ")

    if operacao == "+":
        resultado = num1 + num2
    elif operacao == "-":
        resultado = num1 - num2
    elif operacao == "*":
        resultado = num1 * num2
    elif operacao == "/":
        if num2 != 0:
            resultado = num1 / num2
        else:
            resultado = "Indefinida (divisão por zero)"

    print(f"{num1} {operacao} {num2} = {resultado}")

    with open("calculadora.txt", "a") as arquivo:
        arquivo.write(f"{num1} {operacao} {num2} = {resultado}\n")

    while True:
        continuar = input("Deseja realizar outra operação? (sim/não): ").lower().strip()
        if continuar in ["sim", "s"]:
            break 
        elif continuar in ["não", "n"]:
            print("Encerrando a calculadora.")
            exit_program = True
            break
        else:
            print("Opção inválida! Digite apenas 'sim' ou 'não'.")

    if continuar in ["não", "n"]:
        break
